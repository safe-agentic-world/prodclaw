{
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "action_id",
    "trace_id",
    "action_type",
    "resource",
    "params_hash",
    "principal",
    "agent",
    "environment",
    "action_fingerprint",
    "decision",
    "reason_code",
    "matched_rule_ids",
    "policy_bundle_hash",
    "result_code",
    "retryable",
    "redaction_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["v1"]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "resource": {
      "type": "string",
      "minLength": 1
    },
    "params_hash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "principal": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "ci_identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "repo": { "type": "string" },
        "project": { "type": "string" },
        "ref": { "type": "string" },
        "branch": { "type": "string" },
        "commit_sha": { "type": "string" },
        "run_id": { "type": "string" },
        "pipeline_id": { "type": "string" },
        "workflow_run_id": { "type": "string" },
        "job_id": { "type": "string" },
        "actor": { "type": "string" },
        "event_type": { "type": "string" },
        "workspace_root": { "type": "string" }
      }
    },
    "credential_exposure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_env_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "executor_only_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scrubbed_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "credential_scopes": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "action_fingerprint": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "DENY"]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "matched_rule_ids": {
      "type": "array"
    },
    "policy_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "result_code": {
      "type": "string",
      "minLength": 1
    },
    "retryable": {
      "type": "boolean"
    },
    "redaction_summary": {
      "type": "object",
      "required": ["applied", "truncated"],
      "additionalProperties": false,
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "truncated": {
          "type": "boolean"
        },
        "scanner_rule_pack": {
          "type": "string",
          "minLength": 1
        },
        "return_path_handling": {
          "type": "string",
          "enum": ["allow", "fence", "strip", "deny", "mixed"]
        },
        "scanner_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["rule_id", "severity", "location_kind", "digest"],
            "additionalProperties": false,
            "properties": {
              "rule_id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "minLength": 1
              },
              "location_kind": {
                "type": "string",
                "minLength": 1
              },
              "digest": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64
              }
            }
          }
        },
        "fenced": {
          "type": "boolean"
        },
        "stripped": {
          "type": "boolean"
        },
        "denied": {
          "type": "boolean"
        }
      }
    },
    "returned_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "artifact_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "exec_condition": {
      "type": "string",
      "minLength": 1
    },
    "http_status_code": {
      "type": "integer",
      "minimum": 100,
      "maximum": 599
    },
    "http_final_resource": {
      "type": "string",
      "minLength": 1
    },
    "http_redirect_hops": {
      "type": "integer",
      "minimum": 0
    }
  }
}
